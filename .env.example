# ── Railway 환경변수 설정 예시 ──────────────────────────────
# Railway 대시보드 > Variables 탭에서 아래 값을 설정하세요

# 서버 환경 (Railway 자동 설정됨)
NODE_ENV=production

# JWT 시크릿 — 반드시 변경하세요 (32자 이상 랜덤 문자열 권장)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 추가 허용 CORS 도메인 (홈페이지.html 호스팅 도메인이 있다면 추가)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SQLite DB 경로 (Railway 볼륨 사용 시)
# DB_PATH=/data/starters.db

# 포트 (Railway 자동 주입됨 — 수정 불필요)
# PORT=5000
